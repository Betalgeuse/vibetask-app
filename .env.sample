# Generated by Convex once you install it
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Key (prefer Gemini)
GEMINI_API_KEY=
# Optional OpenAI fallback
OPENAI_API_KEY=

# Convex and Next Auth Creds
CONVEX_AUTH_PRIVATE_KEY=
JWKS=
AUTH_SECRET=
CONVEX_AUTH_ADAPTER_SECRET=

# Create Google Client for Login with Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# v8 calendar foundation callback (same Google OAuth app)
# Add this redirect URI in Google Cloud Console:
# http://localhost:3000/api/auth/callback/google-calendar
